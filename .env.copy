# NVIDIA NIM Configuration
NVIDIA_API_KEY=""
NVIDIA_BASE_URL="https://integrate.api.nvidia.com/v1"
LLM_MODEL="moonshotai/kimi-k2.5"
# Max output tokens for the summary LLM. Raise this only if you still see
# truncated-JSON ("EOF while parsing a string") errors on very long papers.
LLM_MAX_TOKENS=8192

# Rate Limiting & Retry Configuration
MAX_PAPERS_PER_BATCH=1
SUMMARY_MAX_RETRIES=2

# MinIO Object Storage
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_ENDPOINT=""
MINIO_BUCKET=""
MINIO_SECURE=""

# PostgreSQL Database
DATABASE_URL=""

# API & Scheduler
API_PASSWORD=""
RUN_ON_STARTUP="false"

# GitHub Pages deploy trigger (optional)
# After a digest run, the scheduler calls the GitHub API to rebuild the website.
# GITHUB_TOKEN: a token with rights to send repository_dispatch (classic `repo`
#   scope, or a fine-grained PAT with "Contents: write" on the repo).
# GITHUB_REPO: owner/repo to trigger.
GITHUB_TOKEN=""
GITHUB_REPO="gnust-company/daily_papers_digest"
